<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Jameson Watch</title>
  <meta name="theme-color" content="#1d4f91" />
  <style>
    :root {
      --blue-900: #102a5c;
      --blue-800: #163b73;
      --blue-700: #1d4f91;
      --blue-600: #2d6cdf;
      --blue-300: #9dc2ff;
      --blue-100: #dbeafe;
      --blue-50: #eff6ff;
      --night: #101936;
      --moon: #fff3b0;
      --star: #ffe999;
      --ink: #172554;
      --muted: #60739b;
      --green: #1f9d55;
      --red: #c2410c;
      --orange: #fb923c;
      --purple: #7c3aed;
      --card: rgba(255,255,255,0.94);
      --shadow: 0 18px 45px rgba(16, 42, 92, 0.24);
      --soft-shadow: 0 10px 25px rgba(16, 42, 92, 0.14);
      --radius: 28px;
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Trebuchet MS", "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 18% 11%, rgba(255, 233, 153, 0.95) 0 52px, transparent 54px),
        radial-gradient(circle at 81% 7%, rgba(255,255,255,0.84) 0 3px, transparent 4px),
        radial-gradient(circle at 91% 19%, rgba(255,255,255,0.75) 0 4px, transparent 5px),
        radial-gradient(circle at 70% 35%, rgba(255,255,255,0.72) 0 3px, transparent 4px),
        radial-gradient(circle at 13% 36%, rgba(255,255,255,0.74) 0 3px, transparent 4px),
        linear-gradient(180deg, #132653 0%, #285ba9 42%, #dbeafe 100%);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        radial-gradient(circle, rgba(255,255,255,0.9) 0 2px, transparent 3px),
        radial-gradient(circle, rgba(255,255,255,0.65) 0 1.5px, transparent 2.5px);
      background-size: 86px 86px, 132px 132px;
      background-position: 18px 22px, 44px 50px;
      opacity: 0.65;
    }

    .app {
      width: min(1040px, 100%);
      margin: 0 auto;
      padding: 18px 14px 34px;
      position: relative;
      z-index: 1;
    }

    .hero {
      border-radius: 36px;
      padding: 24px 20px 22px;
      margin: 6px 0 14px;
      background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(239,246,255,0.92));
      box-shadow: var(--shadow);
      border: 2px solid rgba(255,255,255,0.9);
      position: relative;
      overflow: hidden;
    }

    .hero::after {
      content: "☁️";
      position: absolute;
      right: 18px;
      top: 18px;
      font-size: 58px;
      opacity: 0.55;
      transform: rotate(-4deg);
    }

    h1 {
      margin: 0 70px 6px 0;
      line-height: 1.02;
      font-size: clamp(2.05rem, 8vw, 4.65rem);
      color: var(--blue-900);
      letter-spacing: -1.6px;
    }

    .subtitle {
      font-size: clamp(1rem, 3.8vw, 1.35rem);
      color: var(--muted);
      margin: 0 0 18px;
      max-width: 760px;
    }

    .status-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .status-card {
      background: white;
      border-radius: 22px;
      padding: 14px;
      box-shadow: var(--soft-shadow);
      border: 1px solid rgba(45,108,223,0.12);
      min-height: 92px;
    }

    .label {
      display: block;
      font-size: 0.82rem;
      color: var(--muted);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.07em;
    }

    .big {
      display: block;
      font-size: clamp(1.35rem, 5vw, 2.2rem);
      font-weight: 900;
      margin-top: 4px;
      color: var(--blue-900);
    }

    .small {
      display: block;
      margin-top: 4px;
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.25;
    }

    .tabs {
      position: sticky;
      top: 0;
      z-index: 10;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      padding: 8px 0 12px;
      backdrop-filter: blur(8px);
    }

    .tab-button {
      background: rgba(255,255,255,0.9);
      color: var(--blue-900);
      border: 2px solid rgba(255,255,255,0.8);
      box-shadow: var(--soft-shadow);
      border-radius: 22px;
      padding: 14px 8px;
      font-weight: 950;
      font-size: clamp(0.92rem, 3.5vw, 1.08rem);
    }

    .tab-button.active {
      background: linear-gradient(180deg, #4f8cff, #245fd2);
      color: white;
    }

    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
      animation: fadeIn 0.18s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .controls {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 14px 0;
    }

    button {
      border: 0;
      border-radius: 24px;
      padding: 16px 18px;
      font: inherit;
      font-weight: 900;
      cursor: pointer;
      box-shadow: var(--soft-shadow);
      transition: transform 0.12s ease, filter 0.12s ease, box-shadow 0.12s ease;
      touch-action: manipulation;
    }

    button:active {
      transform: scale(0.97);
      box-shadow: 0 5px 12px rgba(22, 59, 115, 0.16);
    }

    .primary {
      background: linear-gradient(180deg, #4f8cff, #245fd2);
      color: white;
    }

    .secondary {
      background: white;
      color: var(--blue-900);
      border: 2px solid rgba(45,108,223,0.2);
    }

    .danger {
      background: #fff7ed;
      color: var(--red);
      border: 2px solid rgba(194,65,12,0.18);
    }

    .routine,
    .card-grid {
      display: grid;
      gap: 14px;
    }

    .section-title {
      color: white;
      text-shadow: 0 3px 10px rgba(0,0,0,0.18);
      margin: 22px 6px 8px;
      font-size: 1.4rem;
    }

    .step,
    .rule-card {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 12px;
      background: var(--card);
      border-radius: var(--radius);
      padding: 15px;
      box-shadow: var(--soft-shadow);
      border: 2px solid rgba(255,255,255,0.82);
      position: relative;
      overflow: hidden;
    }

    .rule-card {
      grid-template-columns: auto 1fr;
    }

    .step.done,
    .rule-card.done {
      background: linear-gradient(180deg, #f0fff5, #ffffff);
      border-color: rgba(31,157,85,0.35);
    }

    .icon {
      width: 56px;
      height: 56px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      font-size: 2rem;
      background: var(--blue-100);
      box-shadow: inset 0 -3px 0 rgba(22, 59, 115, 0.07);
    }

    .step h2,
    .rule-card h2,
    .note-card h2 {
      margin: 0;
      font-size: clamp(1.18rem, 4.4vw, 1.7rem);
      color: var(--blue-900);
      line-height: 1.05;
    }

    .step p,
    .rule-card p,
    .note-card p {
      margin: 5px 0 0;
      color: var(--muted);
      font-size: 0.98rem;
      line-height: 1.3;
    }

    .check {
      width: 54px;
      height: 54px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      background: var(--blue-50);
      color: var(--blue-600);
      font-size: 1.45rem;
      border: 2px solid rgba(45,108,223,0.18);
      box-shadow: none;
      padding: 0;
    }

    .step.done .check {
      background: var(--green);
      color: white;
      border-color: var(--green);
    }

    .choice-card,
    .note-card,
    .story-card,
    .timer-card {
      background: var(--card);
      border-radius: var(--radius);
      padding: 18px;
      box-shadow: var(--soft-shadow);
      border: 2px solid rgba(255,255,255,0.88);
    }

    .choice-card h2,
    .story-card h2,
    .timer-card h2 {
      margin: 0 0 8px;
      color: var(--blue-900);
      font-size: clamp(1.3rem, 5vw, 2rem);
    }

    .choice-card p,
    .story-card p,
    .timer-card p {
      margin: 0 0 14px;
      color: var(--muted);
    }

    .choice-buttons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .choice {
      background: white;
      color: var(--blue-900);
      border: 3px solid rgba(45,108,223,0.18);
      min-height: 84px;
      font-size: clamp(1rem, 4vw, 1.35rem);
    }

    .choice.selected {
      background: linear-gradient(180deg, #e0edff, #ffffff);
      border-color: var(--blue-600);
      outline: 4px solid rgba(45,108,223,0.12);
    }

    .progress-wrap {
      background: rgba(255,255,255,0.45);
      border-radius: 999px;
      height: 18px;
      overflow: hidden;
      margin-top: 16px;
      border: 2px solid rgba(255,255,255,0.8);
    }

    .progress {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #8db7ff, #ffe999);
      border-radius: 999px;
      transition: width 0.25s ease;
    }

    .story-controls {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 10px;
      margin-bottom: 10px;
    }

    select {
      width: 100%;
      border: 2px solid rgba(45,108,223,0.2);
      border-radius: 22px;
      padding: 14px;
      font: inherit;
      font-weight: 800;
      color: var(--blue-900);
      background: white;
      box-shadow: var(--soft-shadow);
    }

    .story-box {
      background: white;
      border-radius: 22px;
      padding: 16px;
      color: var(--ink);
      line-height: 1.48;
      border: 1px solid rgba(45,108,223,0.12);
      max-height: 420px;
      overflow: auto;
      white-space: pre-line;
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .pill {
      border-radius: 999px;
      padding: 8px 11px;
      background: white;
      color: var(--blue-900);
      border: 2px solid rgba(45,108,223,0.13);
      font-weight: 900;
      box-shadow: none;
    }

    .allowed {
      border-color: rgba(31,157,85,0.25);
      color: #166534;
      background: #f0fdf4;
    }

    .not-allowed {
      border-color: rgba(194,65,12,0.22);
      color: var(--red);
      background: #fff7ed;
    }

    .timer-display {
      display: grid;
      place-items: center;
      width: min(360px, 100%);
      aspect-ratio: 1 / 1;
      margin: 14px auto;
      border-radius: 50%;
      background:
        conic-gradient(var(--blue-600) var(--timerProgress, 100%), rgba(45,108,223,0.12) 0),
        white;
      box-shadow: var(--shadow);
      position: relative;
    }

    .timer-display::before {
      content: "";
      position: absolute;
      inset: 18px;
      border-radius: 50%;
      background: white;
      box-shadow: inset 0 0 0 2px rgba(45,108,223,0.1);
    }

    .timer-time {
      position: relative;
      z-index: 1;
      font-size: clamp(3rem, 14vw, 5.6rem);
      font-weight: 950;
      color: var(--blue-900);
      letter-spacing: -2px;
    }

    .timer-label {
      position: relative;
      z-index: 1;
      color: var(--muted);
      font-weight: 900;
      margin-top: -6px;
      text-align: center;
    }

    .timer-buttons {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .footer {
      text-align: center;
      color: white;
      margin: 20px 8px 0;
      text-shadow: 0 2px 8px rgba(0,0,0,0.16);
      font-weight: 800;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%) translateY(120px);
      width: min(92vw, 560px);
      background: #111c3a;
      color: white;
      padding: 14px 16px;
      border-radius: 20px;
      box-shadow: 0 18px 40px rgba(0,0,0,0.25);
      z-index: 20;
      transition: transform 0.25s ease;
      text-align: center;
      font-weight: 900;
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
    }

    .star {
      display: inline-block;
      animation: twinkle 2.8s infinite ease-in-out;
    }

    @keyframes twinkle {
      0%, 100% { transform: scale(1); opacity: 0.85; }
      50% { transform: scale(1.18); opacity: 1; }
    }

    @media (max-width: 760px) {
      .status-grid,
      .controls,
      .choice-buttons,
      .story-controls,
      .timer-buttons {
        grid-template-columns: 1fr;
      }

      .tabs {
        gap: 6px;
      }

      .tab-button {
        padding: 13px 6px;
      }

      .step {
        grid-template-columns: auto 1fr;
      }

      .check {
        grid-column: 1 / -1;
        width: 100%;
      }

      .story-box {
        max-height: 360px;
      }
    }

    @media (display-mode: standalone) {
      .app {
        padding-top: max(18px, env(safe-area-inset-top));
      }
    }
  </style>
</head>
<body>
  <main class="app">
    <section class="hero">
      <h1>Jameson Watch <span class="star">✨</span></h1>
      <p class="subtitle">A blue, cozy guide for bedtime, dinner, activities, and calm caregiving while Dad is out.</p>

      <div class="status-grid">
        <div class="status-card">
          <span class="label">Now</span>
          <span class="big" id="nowTime">--:--</span>
          <span class="small" id="todayLabel">Tonight</span>
        </div>
        <div class="status-card">
          <span class="label">Next bedtime reminder</span>
          <span class="big" id="nextReminder">7:30 PM</span>
          <span class="small" id="countdown">Ready when you are</span>
        </div>
        <div class="status-card">
          <span class="label">Bedtime progress</span>
          <span class="big" id="progressText">0%</span>
          <span class="small" id="progressMessage">Sleepy mission not started yet</span>
        </div>
      </div>

      <div class="progress-wrap" aria-label="Bedtime routine progress">
        <div class="progress" id="progressBar"></div>
      </div>
    </section>

    <nav class="tabs" aria-label="App sections">
      <button class="tab-button active" data-tab="bedtime">🌙 Bedtime</button>
      <button class="tab-button" data-tab="feeding">🍽️ Feeding</button>
      <button class="tab-button" data-tab="activities">🧩 Activities</button>
    </nav>

    <section class="controls">
      <button class="primary" id="enableNotifications">🔔 Enable bedtime alerts</button>
      <button class="secondary" id="resetTonight">🌙 Reset tonight</button>
    </section>

    <section class="tab-panel active" id="bedtime">
      <h2 class="section-title">Part 1 — 7:30 PM</h2>
      <section class="routine">
        <article class="step" data-step="melatonin">
          <div class="icon">🌙</div>
          <div>
            <h2>Melatonin</h2>
            <p>At 7:30 PM. Give it 30 minutes before the routine begins, or as the routine begins at the latest.</p>
          </div>
          <button class="check" aria-label="Complete melatonin">✓</button>
        </article>
      </section>

      <h2 class="section-title">Part 2 — 8:00 PM</h2>
      <section class="routine">
        <article class="step" data-step="potty">
          <div class="icon">🚽</div>
          <div>
            <h2>Potty</h2>
            <p>First stop before getting fully cozy.</p>
          </div>
          <button class="check" aria-label="Complete potty">✓</button>
        </article>

        <article class="step" data-step="hands">
          <div class="icon">🫧</div>
          <div>
            <h2>Wash hands</h2>
            <p>Clean hands before bed.</p>
          </div>
          <button class="check" aria-label="Complete wash hands">✓</button>
        </article>

        <article class="step" data-step="teeth">
          <div class="icon">🪥</div>
          <div>
            <h2>Brush teeth</h2>
            <p>Brush, rinse, and smile like a sleepy superhero.</p>
          </div>
          <button class="check" aria-label="Complete brush teeth">✓</button>
        </article>
      </section>

      <section class="choice-card" style="margin-top:14px;">
        <h2>Cozy sleep choice</h2>
        <p>Jameson must choose one. Either choice is okay, but the choice has to be made.</p>
        <div class="choice-buttons">
          <button class="choice" data-choice="pajamas">🧸 Pajamas</button>
          <button class="choice" data-choice="underwear">🛌 Underwear</button>
        </div>
      </section>

      <h2 class="section-title">Room setup</h2>
      <section class="routine">
        <article class="step" data-step="fan">
          <div class="icon">🌀</div>
          <div>
            <h2>Fan on 4</h2>
            <p>Turn the fan on, set it to 4, and point it toward the closet — not the bed. It is for noise, not cooling.</p>
          </div>
          <button class="check" aria-label="Complete fan setup">✓</button>
        </article>

        <article class="step" data-step="alexa">
          <div class="icon">🎵</div>
          <div>
            <h2>Meditation sounds</h2>
            <p>Say: “Alexa, play meditation sounds.” It should be delta waves.</p>
          </div>
          <button class="check" aria-label="Complete meditation sounds">✓</button>
        </article>
      </section>

      <section class="story-card" style="margin-top:14px;">
        <h2>Bedtime story card</h2>
        <p>Choose a story. These are gentle public-domain retellings with the important adventure beats included.</p>
        <div class="story-controls">
          <select id="storySelect" aria-label="Choose bedtime story">
            <option value="gilgamesh">The Epic of Gilgamesh</option>
            <option value="rapunzel">Rapunzel — original rampion version</option>
            <option value="tailor">The Brave Little Tailor</option>
          </select>
          <button class="primary" id="readStory">📖 Show story</button>
        </div>
        <div class="story-box" id="storyBox"></div>
      </section>
    </section>

    <section class="tab-panel" id="feeding">
      <h2 class="section-title">Dinner and snacks</h2>
      <section class="card-grid">
        <article class="rule-card">
          <div class="icon">🍽️</div>
          <div>
            <h2>Dinner will be ordered</h2>
            <p>No cooking plan needed. Order dinner and use the snack/drink rules below.</p>
          </div>
        </article>

        <article class="rule-card">
          <div class="icon">💧</div>
          <div>
            <h2>Drink order</h2>
            <p>Offer Propel flavored water first. Capri Sun is okay if he wants it after that.</p>
            <div class="pill-row">
              <span class="pill allowed">First offer: Propel</span>
              <span class="pill allowed">Capri Sun okay</span>
            </div>
          </div>
        </article>

        <article class="rule-card">
          <div class="icon">🥔</div>
          <div>
            <h2>Chips</h2>
            <p>Chips are okay, but only one bag.</p>
            <div class="pill-row">
              <span class="pill allowed">One bag only</span>
            </div>
          </div>
        </article>

        <article class="rule-card">
          <div class="icon">🍬</div>
          <div>
            <h2>Tiny ones</h2>
            <p>After dinner, he can have the rest of his tiny ones if there are any left.</p>
            <div class="pill-row">
              <span class="pill allowed">After dinner only</span>
            </div>
          </div>
        </article>
      </section>
    </section>

    <section class="tab-panel" id="activities">
      <h2 class="section-title">Best activities</h2>
      <section class="card-grid">
        <article class="rule-card">
          <div class="icon">🧩</div>
          <div>
            <h2>Push Magna-Mosaic</h2>
            <p>Magna-Mosaic is the preferred activity. It is the only thing that can be left out.</p>
            <div class="pill-row">
              <span class="pill allowed">Best choice</span>
              <span class="pill allowed">Can stay out</span>
            </div>
          </div>
        </article>

        <article class="rule-card">
          <div class="icon">🧺</div>
          <div>
            <h2>One thing at a time</h2>
            <p>Everything else needs to be put away before something new is gotten out.</p>
            <div class="pill-row">
              <span class="pill allowed">Clean up first</span>
            </div>
          </div>
        </article>

        <article class="rule-card">
          <div class="icon">🚗</div>
          <div>
            <h2>Yellow car track</h2>
            <p>He can build a track with his yellow car set. Put it away before moving to another activity.</p>
          </div>
        </article>
      </section>

      <section class="timer-card" style="margin-top:14px;">
        <h2>Goat Simulator timer</h2>
        <p>Goat Simulator is an option for 30 minutes. Start the visual timer when gameplay starts.</p>

        <div class="timer-display" id="timerDisplay" style="--timerProgress: 100%;">
          <div>
            <div class="timer-time" id="timerTime">30:00</div>
            <div class="timer-label" id="timerLabel">Ready for gameplay</div>
          </div>
        </div>

        <div class="timer-buttons">
          <button class="primary" id="startGameTimer">▶️ Start 30 min</button>
          <button class="secondary" id="pauseGameTimer">⏸️ Pause</button>
          <button class="danger" id="resetGameTimer">↺ Reset</button>
        </div>
      </section>

      <h2 class="section-title">Not available tonight</h2>
      <section class="card-grid">
        <article class="rule-card">
          <div class="icon">💻</div>
          <div>
            <h2>No computer</h2>
            <p>He cannot use his computer because Dad needs to fix the login.</p>
            <div class="pill-row">
              <span class="pill not-allowed">Not tonight</span>
            </div>
          </div>
        </article>

        <article class="rule-card">
          <div class="icon">🎨</div>
          <div>
            <h2>No art project</h2>
            <p>No art project because the table is taken up with Magna-Mosaic.</p>
            <div class="pill-row">
              <span class="pill not-allowed">Table unavailable</span>
            </div>
          </div>
        </article>

        <article class="rule-card">
          <div class="icon">💦</div>
          <div>
            <h2>No water play</h2>
            <p>No water play because it makes a huge mess.</p>
            <div class="pill-row">
              <span class="pill not-allowed">Too messy</span>
            </div>
          </div>
        </article>
      </section>
    </section>

    <p class="footer">Blue moon, calm choices, clean hands, cozy room, safe fun. 💙</p>
  </main>

  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <script>
    const STORAGE_KEY = "jamesonWatch.v2";
    const GAME_SECONDS = 30 * 60;

    const steps = [
      "melatonin",
      "potty",
      "hands",
      "teeth",
      "choice",
      "fan",
      "alexa"
    ];

    const stories = {
      gilgamesh: `The Epic of Gilgamesh

Long ago, in the great city of Uruk, there was a king named Gilgamesh. He was strong, clever, and brave, but he was also restless and harsh. The people asked the gods for help, and the gods shaped a wild man named Enkidu, who lived among the animals.

Enkidu was powerful, free, and innocent. After he came to the city, he and Gilgamesh wrestled like thunder. Neither could truly defeat the other, and from that struggle they became friends.

Together they wanted to do something mighty. They journeyed to the Cedar Forest, where the fearsome guardian Humbaba watched over the sacred trees. The path was long and frightening, but they encouraged each other. When Humbaba roared, the forest shook. With courage, and with help from the winds, Gilgamesh and Enkidu defeated him.

When they returned, the goddess Ishtar offered Gilgamesh her favor, but he refused her. Angered, she sent the Bull of Heaven against Uruk. The bull brought terror and destruction, but Gilgamesh and Enkidu fought together and defeated it.

The gods decided that Enkidu must die. Enkidu grew sick, and Gilgamesh sat beside him in grief. When Enkidu died, Gilgamesh was shattered. He had been brave before monsters, but now he feared death itself.

So Gilgamesh wandered far from Uruk. He crossed wild mountains and dark places. He found Siduri, who told him that humans cannot live forever and should cherish food, warmth, friendship, and the days they are given. Still, Gilgamesh kept searching.

He crossed the Waters of Death and came to Utnapishtim, the man who had survived the great flood and had been granted eternal life. Utnapishtim told how the gods once sent a flood, how he built a boat, saved living things, and released birds to find land again.

Gilgamesh wanted the secret of eternal life. Utnapishtim tested him by asking him to stay awake for six days and seven nights, but Gilgamesh fell asleep. Before Gilgamesh left, he learned of a plant that could restore youth. He found it beneath the water and carried it home.

But while Gilgamesh bathed, a serpent stole the plant and slipped away, leaving its old skin behind. Gilgamesh wept, but at last he returned to Uruk.

He looked at the city walls: strong, beautiful, and made by human hands. He understood that he would not live forever, but his deeds, his city, his care for his people, and his friendship with Enkidu would matter.

And so Gilgamesh, who had searched for forever, came home wiser than he had left.`,

      rapunzel: `Rapunzel

Once there was a husband and wife who longed for a child. At last they were expecting one. Behind their house was a garden belonging to a powerful enchantress, and in that garden grew rampion, a leafy plant with tempting roots and greens.

The wife saw the rampion and longed for it more and more until she grew pale. Her husband, frightened for her, climbed into the garden and took some. She ate it and wanted more. He returned again, but this time the enchantress caught him.

“How dare you steal from my garden?” she said.

He begged for mercy and explained his wife’s longing. The enchantress allowed him to take the rampion, but only if the child would be given to her when born. Afraid, he agreed.

When the baby girl was born, the enchantress took her and named her Rapunzel. Rapunzel grew into a beautiful child with long golden hair. When she was twelve, the enchantress shut her in a high tower deep in the forest. It had no stairs and no door, only a window at the top.

When the enchantress wanted to enter, she called, “Rapunzel, Rapunzel, let down your hair.” Rapunzel lowered her long braid, and the enchantress climbed up.

One day a prince heard Rapunzel singing. Her voice was so lovely that he returned again and again to listen. He saw the enchantress call for the hair, and after she left, he called the same words.

“Rapunzel, Rapunzel, let down your hair.”

Rapunzel lowered her braid, and the prince climbed up. At first she was frightened, but he spoke kindly. He visited often, and they planned for her escape. He would bring silk each time, and Rapunzel would weave it into a ladder.

But Rapunzel accidentally gave away the secret when she asked the enchantress why she was so much heavier to pull up than the young prince. The enchantress was furious. She cut off Rapunzel’s hair and sent her away into a lonely wilderness.

That evening, when the prince called, the enchantress lowered the cut braid. He climbed up and found not Rapunzel, but the enchantress. In despair, he leapt from the tower. He lived, but thorns injured his eyes, and he wandered blind through the world.

For a long time he roamed, grieving and searching. At last he came to the wilderness and heard a familiar voice singing. It was Rapunzel. She had been living there with the children born to her, a boy and a girl.

Rapunzel recognized him and wept. Her tears fell on his eyes, and his sight returned.

Together they journeyed to his kingdom, where they were welcomed with joy. And after fear, loss, and long wandering, Rapunzel and the prince lived in peace.`,

      tailor: `The Brave Little Tailor

One morning, a little tailor sat sewing by his window. He had bought jam, and when he spread it on bread, flies came buzzing around. The tailor struck them with a cloth and counted seven flies gone at once.

Proud of himself, he made a belt that said, “Seven at one blow.” He put it on and went out into the world, feeling ready for adventure.

People who saw the belt thought he meant seven men or seven giants. Soon a giant met him and challenged him. The giant squeezed water from a stone, but the tailor squeezed cheese and made whey drip out. The giant threw a stone high in the air, but the tailor released a bird, which flew away and did not come down. The giant thought the tailor was mighty indeed.

The giant brought him to a cave with other giants, but the tailor outwitted them and escaped danger. His reputation grew.

A king heard about the brave little tailor and wanted to test him. The kingdom had two terrible giants causing destruction. The king promised great rewards if the tailor could defeat them.

The tailor found the giants asleep under a tree. He threw stones at one, then at the other, making each think the other had struck him. The giants fought each other until both were defeated. The tailor returned as if it had all been easy.

The king was not finished. Next he sent the tailor to capture a fierce unicorn. The tailor stood before a tree. When the unicorn charged, the tailor jumped aside, and the unicorn’s horn stuck fast in the trunk. The tailor calmly tied it up.

Then the king sent him after a wild boar that no one could catch. The tailor lured it into a chapel, slipped out through a window, and shut the door behind it. The boar was trapped.

The king had promised his daughter and half the kingdom to the hero who completed these tasks. Though he tried to avoid keeping his promise, the tailor had done everything asked. The tailor married the princess and became a ruler.

Some people still doubted him because he was only a tailor. One night they planned to listen as he slept, hoping to discover his secret. The tailor heard of the plan and pretended to talk in his sleep. He muttered about swatting seven at one blow, defeating giants, catching a unicorn, and trapping a boar.

The listeners grew frightened and ran away. No one dared trouble him again.

And so the little tailor, who used courage, cleverness, and a little bold bragging, lived happily as a brave and clever king.`
    };

    const defaultState = () => ({
      date: dateKey(new Date()),
      done: {},
      sleepChoice: "",
      alertsSent: alertsForToday(),
      gameSecondsLeft: GAME_SECONDS,
      gameRunning: false,
      gameStartedAt: null
    });

    let state = loadState();
    let gameTimerInterval = null;

    const nowTime = document.getElementById("nowTime");
    const todayLabel = document.getElementById("todayLabel");
    const nextReminder = document.getElementById("nextReminder");
    const countdown = document.getElementById("countdown");
    const progressText = document.getElementById("progressText");
    const progressMessage = document.getElementById("progressMessage");
    const progressBar = document.getElementById("progressBar");
    const toast = document.getElementById("toast");
    const storyBox = document.getElementById("storyBox");
    const timerTime = document.getElementById("timerTime");
    const timerLabel = document.getElementById("timerLabel");
    const timerDisplay = document.getElementById("timerDisplay");

    document.querySelectorAll(".tab-button").forEach(button => {
      button.addEventListener("click", () => {
        const tab = button.dataset.tab;
        document.querySelectorAll(".tab-button").forEach(btn => btn.classList.toggle("active", btn.dataset.tab === tab));
        document.querySelectorAll(".tab-panel").forEach(panel => panel.classList.toggle("active", panel.id === tab));
      });
    });

    document.querySelectorAll(".check").forEach(button => {
      button.addEventListener("click", () => {
        const step = button.closest(".step").dataset.step;
        state.done[step] = !state.done[step];
        saveState();
        render();
      });
    });

    document.querySelectorAll(".choice").forEach(button => {
      button.addEventListener("click", () => {
        state.sleepChoice = button.dataset.choice;
        state.done.choice = true;
        saveState();
        render();
        showToast(state.sleepChoice === "pajamas" ? "Pajamas selected. Cozy choice made. 🧸" : "Underwear selected. Cozy choice made. 🛌");
      });
    });

    document.getElementById("resetTonight").addEventListener("click", () => {
      state = defaultState();
      stopGameTimer();
      saveState();
      render();
      showToast("Tonight has been reset. 🌙");
    });

    document.getElementById("enableNotifications").addEventListener("click", async () => {
      if (!("Notification" in window)) {
        showToast("This browser does not support notifications. Use phone alarms for 7:30 and 8:00.");
        return;
      }

      const permission = await Notification.requestPermission();
      if (permission === "granted") {
        showToast("Bedtime alerts are enabled for this page. Keep it open or installed for best results. 🔔");
        notify("Bedtime alerts enabled", "You should receive reminders at 7:30 PM and 8:00 PM when this page is active.");
      } else {
        showToast("Notifications were not enabled. You can still use the checklist.");
      }
    });

    document.getElementById("readStory").addEventListener("click", () => {
      const key = document.getElementById("storySelect").value;
      storyBox.textContent = stories[key];
      storyBox.scrollTop = 0;
    });

    document.getElementById("startGameTimer").addEventListener("click", () => {
      if (state.gameSecondsLeft <= 0) state.gameSecondsLeft = GAME_SECONDS;
      state.gameRunning = true;
      state.gameStartedAt = Date.now();
      saveState();
      startGameTimer();
      showToast("Goat Simulator timer started: 30 minutes. 🐐");
    });

    document.getElementById("pauseGameTimer").addEventListener("click", () => {
      syncGameTime();
      state.gameRunning = false;
      state.gameStartedAt = null;
      saveState();
      stopGameTimer();
      renderTimer();
      showToast("Game timer paused. ⏸️");
    });

    document.getElementById("resetGameTimer").addEventListener("click", () => {
      state.gameSecondsLeft = GAME_SECONDS;
      state.gameRunning = false;
      state.gameStartedAt = null;
      saveState();
      stopGameTimer();
      renderTimer();
      showToast("Game timer reset to 30:00. ↺");
    });

    function loadState() {
      const today = dateKey(new Date());
      const fresh = defaultState();

      try {
        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY));
        if (!saved || saved.date !== today) return fresh;
        return {
          ...fresh,
          ...saved,
          done: saved.done || {},
          alertsSent: saved.alertsSent || alertsForToday()
        };
      } catch {
        return fresh;
      }
    }

    function saveState() {
      state.date = dateKey(new Date());
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    }

    function alertsForToday() {
      return {
        melatonin730: false,
        routine800: false
      };
    }

    function dateKey(date) {
      return date.toISOString().slice(0, 10);
    }

    function formatTime(date) {
      return date.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" });
    }

    function getTodayAt(hour, minute) {
      const d = new Date();
      d.setHours(hour, minute, 0, 0);
      return d;
    }

    function render() {
      document.querySelectorAll(".step").forEach(card => {
        const step = card.dataset.step;
        card.classList.toggle("done", !!state.done[step]);
      });

      document.querySelectorAll(".choice").forEach(button => {
        button.classList.toggle("selected", state.sleepChoice === button.dataset.choice);
      });

      const completeCount = steps.filter(step => state.done[step]).length;
      const percent = Math.round((completeCount / steps.length) * 100);
      progressText.textContent = percent + "%";
      progressBar.style.width = percent + "%";

      if (percent === 0) {
        progressMessage.textContent = "Sleepy mission not started yet";
      } else if (percent < 100) {
        progressMessage.textContent = completeCount + " of " + steps.length + " stars lit";
      } else {
        progressMessage.textContent = "Bedtime adventure complete";
      }

      renderTimer();
    }

    function tickClock() {
      const now = new Date();
      nowTime.textContent = formatTime(now);
      todayLabel.textContent = now.toLocaleDateString([], { weekday: "long", month: "short", day: "numeric" });

      const t730 = getTodayAt(19, 30);
      const t800 = getTodayAt(20, 0);
      let target;
      let label;

      if (now < t730) {
        target = t730;
        label = "7:30 PM";
      } else if (now < t800) {
        target = t800;
        label = "8:00 PM";
      } else {
        const tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1);
        tomorrow.setHours(19, 30, 0, 0);
        target = tomorrow;
        label = "Tomorrow 7:30 PM";
      }

      nextReminder.textContent = label;
      countdown.textContent = timeUntil(target, now);

      checkAlerts(now);
    }

    function timeUntil(target, now) {
      const diff = Math.max(0, target - now);
      const totalMinutes = Math.ceil(diff / 60000);
      const hours = Math.floor(totalMinutes / 60);
      const minutes = totalMinutes % 60;

      if (hours <= 0 && minutes <= 0) return "Now";
      if (hours <= 0) return minutes + " min away";
      return hours + " hr " + minutes + " min away";
    }

    function checkAlerts(now) {
      const today = dateKey(now);
      if (state.date !== today) {
        state = defaultState();
        stopGameTimer();
        saveState();
        render();
      }

      const minutes = now.getHours() * 60 + now.getMinutes();

      if (minutes >= (19 * 60 + 30) && !state.alertsSent.melatonin730) {
        state.alertsSent.melatonin730 = true;
        saveState();
        showToast("7:30 PM: Melatonin time. Start the bedtime countdown. 🌙");
        notify("Jameson's bedtime", "7:30 PM: Melatonin time. Start the bedtime countdown.");
      }

      if (minutes >= (20 * 60) && !state.alertsSent.routine800) {
        state.alertsSent.routine800 = true;
        saveState();
        showToast("8:00 PM: Potty, hands, teeth, cozy choice, fan, and meditation sounds. 💙");
        notify("Jameson's bedtime routine", "8:00 PM: Start potty, hands, teeth, sleep choice, fan, and meditation sounds.");
      }
    }

    function startGameTimer() {
      stopGameTimer();
      gameTimerInterval = setInterval(() => {
        syncGameTime();
        if (state.gameSecondsLeft <= 0) {
          state.gameSecondsLeft = 0;
          state.gameRunning = false;
          state.gameStartedAt = null;
          saveState();
          stopGameTimer();
          showToast("Goat Simulator time is done. Time to put it away. ⭐");
          notify("Goat Simulator timer", "30 minutes are done. Time to put it away.");
        }
        renderTimer();
      }, 500);
    }

    function stopGameTimer() {
      if (gameTimerInterval) {
        clearInterval(gameTimerInterval);
        gameTimerInterval = null;
      }
    }

    function syncGameTime() {
      if (!state.gameRunning || !state.gameStartedAt) return;

      const elapsed = Math.floor((Date.now() - state.gameStartedAt) / 1000);
      if (elapsed <= 0) return;

      state.gameSecondsLeft = Math.max(0, state.gameSecondsLeft - elapsed);
      state.gameStartedAt = Date.now();
      saveState();
    }

    function renderTimer() {
      const seconds = Math.max(0, Math.round(state.gameSecondsLeft));
      const minutes = Math.floor(seconds / 60);
      const remainder = seconds % 60;
      timerTime.textContent = String(minutes).padStart(2, "0") + ":" + String(remainder).padStart(2, "0");

      const progress = Math.max(0, Math.min(100, (seconds / GAME_SECONDS) * 100));
      timerDisplay.style.setProperty("--timerProgress", progress + "%");

      if (seconds === GAME_SECONDS && !state.gameRunning) {
        timerLabel.textContent = "Ready for gameplay";
      } else if (seconds <= 0) {
        timerLabel.textContent = "Time is done";
      } else if (state.gameRunning) {
        timerLabel.textContent = "Goat Simulator time";
      } else {
        timerLabel.textContent = "Paused";
      }
    }

    function notify(title, body) {
      if (!("Notification" in window)) return;
      if (Notification.permission !== "granted") return;

      try {
        new Notification(title, {
          body,
          tag: "jameson-watch",
          renotify: true
        });
      } catch {
        // Some mobile browsers restrict notifications from non-installed pages.
      }
    }

    let toastTimer;
    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove("show"), 4200);
    }

    storyBox.textContent = stories.gilgamesh;
    render();
    tickClock();
    setInterval(tickClock, 15000);

    if (state.gameRunning) {
      startGameTimer();
    }
  </script>
</body>
</html>
